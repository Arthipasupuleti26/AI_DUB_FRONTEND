<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1F5FE"
    tools:context=".VideoExportActivity">

    <!-- Video Area -->
    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_sheet"
        app:layout_constraintTop_toTopOf="parent">

        <VideoView
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Subtitle Overlay -->
        <TextView
            android:id="@+id/tv_subtitle_overlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="64dp"
            android:background="#80000000"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Subtitle Text Shows Here"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Back Button -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/peony"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Center Play Button -->
    <ImageView
        android:id="@+id/btn_center_play"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_circle_translucent"
        android:padding="16dp"
        android:src="@drawable/ic_play_arrow"
        app:tint="@color/peony"
        app:layout_constraintBottom_toTopOf="@+id/bottom_sheet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Controls Overlay (Above Bottom Sheet) -->
    <LinearLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_fade_gradient_black_bottom"
        app:layout_constraintBottom_toTopOf="@+id/bottom_sheet">

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/video_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progress="15"
            android:max="100"
            android:progressTint="@color/peony"
            android:progressBackgroundTint="#55FFFFFF"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_video_timing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00 / 00:00"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginEnd="16dp"/>

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <!-- Rewind -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_skip_previous"
                app:tint="@color/peony"
                android:layout_marginEnd="24dp"/>

            <!-- Play -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_play_arrow"
                app:tint="@color/peony"
                android:layout_marginEnd="24dp"/>

            <!-- Forward -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_skip_next"
                app:tint="@color/peony"
                android:layout_marginEnd="24dp"/>

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <!-- Settings/Sliders -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tune"
                app:tint="@color/peony"/>

        </LinearLayout>
    </LinearLayout>


    <!-- Bottom Sheet -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E1F5FE"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_comparison"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_outline_peony"
            android:text="Comparison"
            android:textAllCaps="false"
            android:textColor="@color/peony"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/btn_edit_sync"
            app:layout_constraintEnd_toStartOf="@+id/btn_subtitle_preview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_weight="1"/>

        <Button
            android:id="@+id/btn_subtitle_preview"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_outline_peony"
            android:text="Subtitles"
            android:textAllCaps="false"
            android:textColor="@color/peony"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/btn_edit_sync"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn_comparison"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_weight="1"/>

        <Button
            android:id="@+id/btn_edit_sync"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_outline_peony"
            android:text="Edit Sync"
            android:textAllCaps="false"
            android:textColor="@color/peony"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_export"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn_subtitle_preview"
            app:layout_constraintHorizontal_weight="1"/>

        <Button
            android:id="@+id/btn_export"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/peony"
            android:text="Export"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn_edit_sync"
            app:layout_constraintTop_toBottomOf="@+id/btn_subtitle_preview"
            app:layout_constraintHorizontal_weight="1"/>


        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Download Video"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_download"
            app:backgroundTint="@color/peony"
            app:elevation="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
