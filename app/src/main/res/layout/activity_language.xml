<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1F5FE"
    tools:context=".LanguageActivity">

    <!-- Header -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/peony"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="App Language"
        android:textColor="#374151"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back"
        app:layout_constraintStart_toEndOf="@+id/btn_back"
        app:layout_constraintTop_toTopOf="@+id/btn_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_header">

        <RadioGroup
            android:id="@+id/radio_group_languages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <RadioButton
                android:id="@+id/rb_english"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="English"
                android:textColor="#374151"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_project_card"
                android:backgroundTint="#FFFFFF"
                android:buttonTint="@color/peony"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_spanish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Spanish (Español)"
                android:textColor="#374151"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_project_card"
                android:backgroundTint="#FFFFFF"
                android:buttonTint="@color/peony"/>

            <RadioButton
                android:id="@+id/rb_french"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="French (Français)"
                android:textColor="#374151"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_project_card"
                android:backgroundTint="#FFFFFF"
                android:buttonTint="@color/peony"/>

            <RadioButton
                android:id="@+id/rb_german"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="German (Deutsch)"
                android:textColor="#374151"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_project_card"
                android:backgroundTint="#FFFFFF"
                android:buttonTint="@color/peony"/>
                
            <RadioButton
                android:id="@+id/rb_chinese"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chinese (中文)"
                android:textColor="#374151"
                android:textSize="16sp"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_project_card"
                android:backgroundTint="#FFFFFF"
                android:buttonTint="@color/peony"/>

        </RadioGroup>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
