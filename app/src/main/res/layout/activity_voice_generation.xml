<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1F5FE"
    tools:context=".VoiceGenerationActivity">

    <!-- Header Title -->
    <TextView
        android:id="@+id/tv_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Generating AI Voice"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Center Animation (Waveform/Speaker) -->
    <LinearLayout
        android:id="@+id/animation_container"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/tv_status"
        app:layout_constraintTop_toBottomOf="@+id/tv_header"
        app:layout_constraintVertical_bias="0.4">

        <!-- Animated Bars (Reusing the bars from ExtractAudio, simple version) -->
        <View
            android:id="@+id/bar1"
            android:layout_width="6dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_waveform_bar" />

        <View
            android:id="@+id/bar2"
            android:layout_width="6dp"
            android:layout_height="60dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_waveform_bar_dark" />

        <View
            android:id="@+id/bar3"
            android:layout_width="6dp"
            android:layout_height="80dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_waveform_bar" />

        <View
            android:id="@+id/bar4"
            android:layout_width="6dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_waveform_bar_dark" />

        <View
            android:id="@+id/bar5"
            android:layout_width="6dp"
            android:layout_height="70dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_waveform_bar" />
            
    </LinearLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Synthesizing voice..."
        android:textColor="@color/gray_600"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/progress_container"
        app:layout_constraintStart_toStartOf="@+id/progress_container" />

    <!-- Progress Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progress_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_next"
        app:layout_constraintTop_toBottomOf="@+id/animation_container">

        <!-- Percentage -->
        <TextView
            android:id="@+id/tv_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="0%"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/progress_bar"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/peony"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Next Button (Initially Hidden) -->
    <Button
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/peony"
        android:text="Next"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
